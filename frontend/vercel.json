{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/:path(.*)",
      "destination": "https://neco-080aad15.fastapicloud.dev/api/v1/:path"
    },
    {
      "source": "/:path((?!.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/index.html"
    }
  ]
}
